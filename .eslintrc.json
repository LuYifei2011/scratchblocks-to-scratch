{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "indent": ["error", 2],
    "linebreak-style": ["error", "unix"],
    "quotes": ["error", "single", { "avoidEscape": true }],
    "semi": ["error", "always"],
    "no-console": "warn",
    "no-unused-vars": ["error", { "args": "none" }],
    "no-trailing-spaces": "error",
    "eqeqeq": ["error", "always"],
    "curly": ["error", "all"]
  }
}
